# ── Caddy GUI – environment variable reference ────────────────────────────
# Copy this file to .env and adjust the values for your setup.

# Path to your Caddyfile on the host (mounted into the GUI container)
CADDYFILE_DIR=/path/to/your/caddy/config

# Path to your Caddy data directory on the host (for root CA certificate)
CADDY_DATA_DIR=/path/to/your/caddy/data

# Name of the Caddy Docker container (used to exec caddy reload)
CADDY_CONTAINER=caddy

# Path to the Caddyfile *inside* the Caddy container
CADDY_CONFIG_PATH=/etc/caddy/Caddyfile

# Port the GUI web server listens on (host port)
PORT=5000

# Hostname this GUI app is served at in the Caddyfile (optional).
# When set, the entry is marked "This app" in the UI and editing it
# will trigger an automatic redirect to the new hostname after save.
SELF_HOSTNAME=caddy-ui.example.local

# Path to the root CA certificate *inside* the GUI container
CADDY_CERT_PATH=/caddydata/pki/authorities/local/root.crt

# Docker network that both Caddy and this container share
CADDY_NETWORK=caddy
